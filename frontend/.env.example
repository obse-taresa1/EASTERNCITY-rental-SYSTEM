# ==============================================================
#  FRONTEND ENVIRONMENT VARIABLES — EASTERNCITY Rental System
# ==============================================================
#  Copy this file to .env and fill in your local values.
#  NEVER commit .env to version control.
# ==============================================================

# Base URL of the backend API server (do NOT include /api — paths already include it)
VITE_API_BASE_URL=http://localhost:5000

# Set to false to use the real backend for authentication.
# Set to true only for isolated frontend development/testing.
VITE_USE_MOCK_AUTH=false

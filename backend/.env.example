# ==============================================================
#  BACKEND ENVIRONMENT VARIABLES — EASTERNCITY Rental System
# ==============================================================
#  Copy this file to .env and fill in your local values.
#  NEVER commit .env to version control.
# ==============================================================

# ── Server ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ───────────────────────────────────────────────────
# PostgreSQL connection string (e.g. Neon, Supabase, or local)
DATABASE_URL=

# ── Authentication ─────────────────────────────────────────────
# Strong random strings — change before deploying to production
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── CORS & Client ──────────────────────────────────────────────
# URL of the running frontend application
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# ── Email / SMTP ───────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=
MAIL_FROM=EasternCity <no-reply@easterncity.com>

# ── Seeding ────────────────────────────────────────────────────
# Used only when running: npx prisma db seed
SEED_SUPER_ADMIN_EMAIL=superadmin@example.com
SEED_SUPER_ADMIN_PASSWORD=
SEED_SUPER_ADMIN_NAME=Super Admin

# ── Uploads Cleanup ────────────────────────────────────────────
# Number of days before uploaded files are cleaned up
UPLOAD_CLEANUP_DAYS=7

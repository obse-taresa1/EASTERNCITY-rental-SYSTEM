generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                            String               @id @default(uuid())
  name                          String
  email                         String               @unique
  password                      String
  role                          String               @default("USER") // USER, ADMIN, SUPER_ADMIN
  createdAt                     DateTime             @default(now())
  rentedBookings                Booking[]            @relation("BookingRenter")
  ownedBookings                 Booking[]            @relation("BookingOwner")
  conversationsAsParticipantOne Conversation[]       @relation("ConversationParticipantOne")
  conversationsAsParticipantTwo Conversation[]       @relation("ConversationParticipantTwo")
  updatedSettings               SystemSetting[]      @relation("SystemSettingUpdater")
  refreshTokens                 RefreshToken[]
  notifications                 Notification[]
  listings                      Listing[]            @relation("ListingOwner")
  approvedListings              Listing[]            @relation("ListingApprover")
  promotions                    Promotion[]          @relation("PromotionRequester")
  approvedPromotions            Promotion[]          @relation("PromotionApprover")
  reviews                       Review[]
  sentMessages                  Message[]            @relation("MessageSender")
  supportTickets                SupportTicket[]      @relation("SupportTicketUser")
  supportTicketReplies          SupportTicketReply[] @relation("SupportTicketReplySender")
}

model Listing {
  id              String    @id @default(uuid())
  title           String
  description     String
  ownerId         String
  categoryId      String?
  city            String
  location        String?
  pricePerDay     Decimal
  status          String    @default("PENDING")
  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  owner         User           @relation("ListingOwner", fields: [ownerId], references: [id])
  approvedBy    User?          @relation("ListingApprover", fields: [approvedById], references: [id])
  category      Category?      @relation(fields: [categoryId], references: [id])
  bookings      Booking[]
  conversations Conversation[]
  images        ListingImage[]
  promotions    Promotion[]
  reviews       Review[]
}

enum BookingStatus {
  PENDING
  ACCEPTED
  ACTIVE
  COMPLETED
  CANCELLED
  REJECTED
}

model Booking {
  id                 String        @id @default(uuid())
  renterId           String
  ownerId            String
  listingId          String
  startDate          DateTime
  endDate            DateTime
  subtotal           Decimal       @db.Decimal(10, 2)
  serviceFee         Decimal       @db.Decimal(10, 2)
  totalAmount        Decimal       @db.Decimal(10, 2)
  agreementAccepted  Boolean       @default(false)
  cancellationReason String?
  approvedAt         DateTime?
  completedAt        DateTime?
  status             BookingStatus @default(PENDING)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  renter  User    @relation("BookingRenter", fields: [renterId], references: [id], onDelete: Cascade)
  owner   User    @relation("BookingOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([renterId])
  @@index([ownerId])
  @@index([listingId])
  @@index([status])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  body           String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model SupportTicket {
  id         String                @id @default(uuid())
  userId     String
  subject    String
  message    String
  status     SupportTicketStatus   @default(OPEN)
  priority   SupportTicketPriority @default(MEDIUM)
  resolvedAt DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  user    User                 @relation("SupportTicketUser", fields: [userId], references: [id], onDelete: Cascade)
  replies SupportTicketReply[]

  @@index([userId])
  @@index([status])
}

model SupportTicketReply {
  id        String   @id @default(uuid())
  ticketId  String
  senderId  String
  message   String
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User          @relation("SupportTicketReplySender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([senderId])
}

model Conversation {
  id               String    @id @default(uuid())
  participantOneId String
  participantTwoId String
  listingId        String
  lastMessageAt    DateTime?
  createdAt        DateTime  @default(now())
  participantOne   User      @relation("ConversationParticipantOne", fields: [participantOneId], references: [id])
  participantTwo   User      @relation("ConversationParticipantTwo", fields: [participantTwoId], references: [id])
  listing          Listing   @relation(fields: [listingId], references: [id])
  Message          Message[]
}

model ListingImage {
  id        String   @id @default(uuid())
  listingId String
  imageUrl  String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id])
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  listings    Listing[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Promotion {
  id              String    @id @default(uuid())
  userId          String
  listingId       String
  packageType     String
  placement       String
  amount          Decimal
  paymentType     String
  paymentProofUrl String?
  status          String    @default("PENDING")
  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user       User    @relation("PromotionRequester", fields: [userId], references: [id])
  listing    Listing @relation(fields: [listingId], references: [id])
  approvedBy User?   @relation("PromotionApprover", fields: [approvedById], references: [id])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  listingId String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  listing Listing @relation(fields: [listingId], references: [id])
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  updatedById String?
  updatedAt   DateTime @updatedAt
  updatedBy   User?    @relation("SystemSettingUpdater", fields: [updatedById], references: [id])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
}

model Notification {
  id            String   @id @default(uuid())
  userId        String
  title         String
  body          String
  type          String
  referenceId   String?
  referenceType String?
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
}

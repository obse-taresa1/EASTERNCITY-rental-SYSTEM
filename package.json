{
  "name": "easterncity-rental-system",
  "private": true,
  "version": "1.0.0",
  "description": "Full-stack rental marketplace with React/Vite frontend and Express/Prisma backend.",
  "scripts": {
    "install:frontend": "npm --prefix frontend install",
    "install:backend": "npm --prefix backend install",
    "install:all": "npm --prefix frontend install && npm --prefix backend install",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "build:frontend": "npm --prefix frontend run build",
    "lint:frontend": "npm --prefix frontend run lint",
    "prisma:generate": "npm --prefix backend run prisma:generate",
    "test:backend": "npm --prefix backend test"
  },
